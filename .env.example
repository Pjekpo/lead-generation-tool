PORT=3000
APIFY_TOKEN=your_apify_token_here

# Actor run options
APIFY_WAIT_SECS=180
APIFY_DEFAULT_MEMORY_MBYTES=1024
APIFY_SOURCE_CONCURRENCY=1

# Set one actor per source (your own actor IDs or Apify Store actor IDs)
APIFY_ACTOR_GOOGLE_MAPS=
APIFY_ACTOR_FACEBOOK=

# Optional per-source memory overrides
# APIFY_MEMORY_MBYTES_GOOGLE_MAPS=1024
# APIFY_MEMORY_MBYTES_FACEBOOK=1024

# Qualification threshold (0-100)
LEAD_QUALIFICATION_THRESHOLD=65

# App access control
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change_this_before_deploy
# APP_SESSION_TTL_HOURS=12
# APP_AUTH_MAX_ATTEMPTS=5
# APP_AUTH_WINDOW_MINUTES=10
# APP_API_MAX_REQUESTS=30
# APP_API_WINDOW_MINUTES=15

# Optional: override actor input schema with JSON templates.
# Tokens:
# {{companyType}}, {{serviceNeed}}, {{location}}, {{limit}}, {{query}},
# {{searchQuery}}, {{searchTopic}}, {{intentQueries}},
# {{timeWindow}}, {{timeWindowLabel}},
# {{sinceDateIso}}, {{sinceEpochMs}}, {{sinceEpochSec}}
# Example:
# APIFY_INPUT_TEMPLATE_GOOGLE_MAPS={"searchStringsArray":["{{searchTopic}}"],"locationQuery":"{{location}}","maxCrawledPlacesPerSearch":"{{limit}}","language":"en"}
# APIFY_INPUT_TEMPLATE_FACEBOOK={"startUrls":[{"url":"https://www.facebook.com/humansofnewyork/"}],"resultsLimit":"{{limit}}","captionText":false}
